{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Waffle chart showing that 35 out of 100 workers have received formal AI training.",
  "title": "Only 35 out of 100 workers received formal AI training",
  "width": 400,
  "height": 400,
  "data": {
    "url": "chart_03_training_waffle.csv",
    "format": {
      "type": "csv"
    }
  },
"transform": [
  {
    "calculate": "datum.status === 'Received formal AI training' ? 'suitcase_black.png' : 'suitcase_white.png'",
    "as": "suitcase_icon"
  }
],
"mark": {
  "type": "image",
  "width": 30,
  "height": 30
},
  "encoding": {
    "x": {
      "field": "col",
      "type": "ordinal",
      "axis": null
    },
    "y": {
      "field": "row",
      "type": "ordinal",
      "sort": "descending",
      "axis": null
    },
      "url": {
      "field": "suitcase_icon",
      "type": "nominal"
    },
    "tooltip": [
      {
        "field": "status",
        "title": "Status"
      },
      {
        "field": "source",
        "title": "Source"
      }
    ]
  },
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 12,
      "gridColor": "#ececec"
    },
    "legend": {
      "orient": "bottom"
    },
    "title": {
      "font": "Arial",
      "fontSize": 16,
      "anchor": "start",
      "fontWeight": "bold"
    }
  }
}