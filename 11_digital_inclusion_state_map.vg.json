{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Australian state and territory map coloured by 2025 Digital Inclusion Index score.",
  "title": "Digital foundations for AI readiness differ by place",
  "width": 620,
  "height": 460,
  "data": {
    "url": "https://raw.githubusercontent.com/rowanhogan/australian-states/master/states.geojson",
    "format": {
      "type": "geojson"
    }
  },
  "transform": [
    {
      "lookup": "properties.STATE_NAME",
      "from": {
        "data": {
          "url": "chart_11_digital_inclusion_state_scores.csv",
          "format": {
            "type": "csv"
          }
        },
        "key": "state",
        "fields": [
          "abbr",
          "score",
          "national_average",
          "source",
          "source_url"
        ]
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": [
      134,
      -28
    ],
    "scale": 560,
    "translate": [
      310,
      230
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "geoshape",
        "fill": "#E5E7EB",
        "stroke": "white",
        "strokeWidth": 1
      }
    },
    {
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "color": {
          "field": "score",
          "type": "quantitative",
          "title": "ADII score",
          "scale": {
            "scheme": "blues",
            "domain": [
              69,
              80
            ]
          }
        },
        "tooltip": [
          {
            "field": "properties.STATE_NAME",
            "title": "State / territory"
          },
          {
            "field": "abbr",
            "title": "Abbrev."
          },
          {
            "field": "score",
            "title": "Digital Inclusion Index",
            "format": ".1f"
          },
          {
            "field": "source",
            "title": "Source"
          }
        ]
      }
    }
  ],
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 12,
      "gridColor": "#ececec"
    },
    "legend": {
      "labelFont": "Arial",
      "titleFont": "Arial",
      "labelFontSize": 12,
      "titleFontSize": 12
    },
    "title": {
      "font": "Arial",
      "fontSize": 16,
      "anchor": "start",
      "fontWeight": "bold"
    }
  }
}